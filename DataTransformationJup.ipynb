import pandas as pd

df = pd.read_csv('Loan_Data.csv')
print(df)


# ==========================================================================================================================================================
# ==========================================================================================================================================================
# #2.Data Preparation/Data pre-processing 
# ---------Data cleaning 
#           --- wrong data (this is done first cos it influences the mean and median)
#           --- wrong datatype
#           --- wrong duplicates
#           --- missing data
#           --- outliers
#           --- unimportant data
# ---------Data Transformation
# =============================================================================
# ==========================================================================================================================================================
# ==========================================================================================================================================================

#           --- wrong data (this is done first cos it influences the mean and median)

print(df[df['Dependents']== '3+'])
#to get the list of load ids that have the 3+ value
print(df[df['Dependents']== '3+']['Loan_ID'].to_list())


df.replace({'Dependents': {'3+': 3}}, inplace=True)
df['Dependents'] = pd.to_numeric(df['Dependents'],errors='coerce')
 
# =============================================================================
# =============================================================================
# unique = df['Dependents'].unique()
# print(unique)
# this is only testing the unique values in the col after the 3+ is replaced
# =============================================================================

# 1. Tell pandas to show ALL columns and then reset it back 
pd.set_option('display.max_columns', None)
print(df)
pd.reset_option('display.max_columns')

df['Gender'].fillna(df['Gender'].mode()[0], inplace=True)
df['Dependents'].fillna(df['Dependents'].mode()[0], inplace=True)
df['Self_Employed'].fillna(df['Self_Employed'].mode()[0], inplace=True)
df['Married'].fillna(df['Married'].mode()[0], inplace=True)

df.dropna(inplace = True)
print(df)
